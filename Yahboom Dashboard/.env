# ─── Flask Backend ───────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=3000
FLASK_DEBUG=false

# ─── MQTT Broker (Yahboom WiFi / Raspberry Pi) ───────────────────────────────
MQTT_BROKER_IP=raspberrypi.local
MQTT_BROKER_PORT=1883
MQTT_TOPIC=yahboom/cmd
MQTT_TIMEOUT=60
MQTT_PUBLISH_TIMEOUT=1

# ─── Raspberry Pi SSH (used to start/stop webrtc_server.py remotely) ──────────
PI_SSH_USER=pi
PI_SSH_PASSWORD=yahboom
# PI_SSH_KEY_PATH=          # optional: absolute path to your private key file
PI_VIDEO_VENV=~/vit_env/bin/activate
PI_VIDEO_SERVER_PATH=webrtc_server.py
PI_VIDEO_SERVER_LOG=/tmp/yahboom_video_server.log
VIDEO_SERVER_PORT=8080
# Terminal emulator on the Pi desktop (lxterminal for Raspberry Pi OS)p
PI_TERMINAL=lxterminal

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Base URL of the Flask backend used by the Vite dev-server proxy
VITE_API_URL=http://localhost:3000