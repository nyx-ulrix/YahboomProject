{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dashboard: Backend",
      "type": "npm",
      "script": "dev:backend",
      "path": "Yahboom Dashboard/",
      "isBackground": true,
      "problemMatcher": {
        "owner": "flask",
        "pattern": {
          "regexp": "^.*Running on (https?://\\S+).*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*\\* Serving Flask app",
          "endsPattern": "Running on (https?://\\S+)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dashboard"
      }
    },
    {
      "label": "Dashboard: Frontend",
      "type": "npm",
      "script": "dev",
      "path": "Yahboom Dashboard/",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dashboard"
      }
    },
    {
      "label": "Run Dashboard",
      "dependsOn": [
        "Dashboard: Backend",
        "Dashboard: Frontend"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
